<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }} — Splinter</title>
  {% include "head.njk" %}
  <link rel="stylesheet" href="/splinter.css">
</head>
<body>

<div class="scanline"></div>

<nav class="spl-nav">
  <a href="/" class="spl-logo">SPLINTER<span>⚡</span></a>
  <div class="spl-nav-links">
    <a href="/core/" {% if nav_order == 1 and not parent %}class="active"{% endif %}>core api</a>
    <a href="/bindings/" {% if title == "Language Bindings (FFI)" or parent == "Language Bindings (FFI)" %}class="active"{% endif %}>ffi</a>
    <a href="/cli/" {% if title == "Command Line Interfaces" or parent == "Command Line Interfaces" %}class="active"{% endif %}>cli</a>
    <a href="/use-cases/">use cases</a>
    <a href="https://github.com/splinterhq/libsplinter" class="gh">github</a>
  </div>
</nav>

<div class="spl-content-wrap">
  <div class="spl-page">

    <div class="spl-breadcrumb">
      <a href="/">~</a>
      <span class="sep">/</span>
      {% if parent %}
        <a href="../">{{ parent }}</a>
        <span class="sep">/</span>
        <span>{{ title }}</span>
      {% else %}
        <span>{{ title }}</span>
      {% endif %}
    </div>

    {% if title == "Language Bindings (FFI)" or parent == "Language Bindings (FFI)" %}
    <nav class="spl-subnav">
      <span class="spl-subnav-label">// bindings</span>
      <a href="/bindings/" {% if title == "Language Bindings (FFI)" %}class="active"{% endif %}>overview</a>
      <a href="/bindings/rust/" {% if title == "Rust" %}class="active"{% endif %}>rust</a>
      <a href="/bindings/java/" {% if title == "Java" %}class="active"{% endif %}>java</a>
      <a href="/bindings/python/" {% if title == "Python 3" %}class="active"{% endif %}>python</a>
      <a href="/bindings/typescript/" {% if title == "TypeScript" %}class="active"{% endif %}>typescript</a>
      <a href="/bindings/lua/" {% if title == "Lua" %}class="active"{% endif %}>lua</a>
      <a href="/bindings/shell/" {% if title == "Shell" %}class="active"{% endif %}>shell</a>
    </nav>
    {% endif %}

    {{ content | safe }}

    <div class="spl-page-nav">
      {% if parent %}
        <a href="../">← {{ parent }}</a>
      {% else %}
        <a href="/">← home</a>
      {% endif %}
      <span>// splinter docs</span>
    </div>

  </div>
</div>

<footer class="spl-footer">
  <p>Splinter is independent research software. <a href="https://buymeacoffee.com/timthepost">buy Tim a coffee</a> if it's saving you time.</p>
  <p><a href="https://github.com/splinterhq/libsplinter">github.com/splinterhq/libsplinter</a></p>
</footer>

</body>
</html>
