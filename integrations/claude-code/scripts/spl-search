#!/bin/bash
# spl-search <query> [--scope journal|ingest|ipc|all] [splinterpctl search flags...]
#
# Scoped semantic search. The --scope flag selects which label set the search
# is restricted to. Without --scope, all embedded slots are searched.
#
# Use this for finding specific passages in ingested files. Use spl-recall
# for journal-only queries (it is just a thin wrapper that pins --scope=journal).

set -e

STORE="${SPLINTER_AGENT_BUS:-.claude/memory.spl}"
SCOPE="all"
PASSTHRU=()
QUERY=""

while [ "$#" -gt 0 ]; do
    case "$1" in
        -h|--help)
            cat <<EOF
Usage: $(basename "$0") <query> [--scope journal|ingest|ipc|all] [flags...]

Scopes (bloom mask applied):
  journal   0x100   (entries written by spl-journal)
  ingest    0x200   (file chunks written by spl-ingest)
  ipc       0x800   (inter-agent messages)
  all                no bloom filter (default)

Pass-through flags accepted: --limit N, --similarity F, --distance F,
--regex PATTERN, --json. Use - as the query to read from stdin.

Environment:
  SPLINTER_AGENT_BUS  Bus path (default: .claude/memory.spl)
EOF
            exit 0
            ;;
        --scope)
            SCOPE="$2"
            shift 2
            ;;
        *)
            if [ -z "$QUERY" ]; then
                QUERY="$1"
                shift
            else
                PASSTHRU+=("$1")
                shift
            fi
            ;;
    esac
done

if [ -z "$QUERY" ]; then
    echo "spl-search: query required (use - for stdin)" >&2
    exit 1
fi

case "$SCOPE" in
    journal) BLOOM="0x100" ;;
    ingest)  BLOOM="0x200" ;;
    ipc)     BLOOM="0x800" ;;
    all)     BLOOM="" ;;
    *)
        echo "spl-search: unknown scope '$SCOPE' (use journal|ingest|ipc|all)" >&2
        exit 1
        ;;
esac

if [ -n "$BLOOM" ]; then
    exec splinterpctl --use "$STORE" search "$QUERY" --bloom "$BLOOM" "${PASSTHRU[@]}"
else
    exec splinterpctl --use "$STORE" search "$QUERY" "${PASSTHRU[@]}"
fi
