#!/bin/bash
# spl-recall <query>
#
# Semantic search across journal entries only (bloom 0x100). The first thing
# an agent should run before starting non-trivial work: "have I seen this
# before? did I leave myself a note?"
#
# Pretty by default; --json for machine-readable output.
#
# Note: splinference embeds VARTEXT writes asynchronously. An entry written
# in the last ~second may not be searchable yet. Across tool calls or runs,
# embeddings have always landed by the time you query.

set -e

STORE="${SPLINTER_AGENT_BUS:-.claude/memory.spl}"
JOURNAL_LABEL="0x100"
PASSTHRU=()
QUERY=""

for arg in "$@"; do
    case "$arg" in
        -h|--help)
            cat <<EOF
Usage: $(basename "$0") <query> [--limit N] [--similarity F] [--json]

Searches the journal for prior decisions, gotchas, and outcomes by meaning.

  <query>          Natural-language phrase. Use - to read from stdin.
  --limit N        Max results (default: 5)
  --similarity F   Minimum cosine similarity (default: 0.4)
  --json           Machine-readable output

Environment:
  SPLINTER_AGENT_BUS  Bus path (default: .claude/memory.spl)
EOF
            exit 0
            ;;
        --json|--limit|--similarity|--distance|--regex)
            PASSTHRU+=("$arg")
            ;;
        *)
            if [ -z "$QUERY" ]; then
                QUERY="$arg"
            else
                PASSTHRU+=("$arg")
            fi
            ;;
    esac
done

if [ -z "$QUERY" ]; then
    echo "spl-recall: query required (use - for stdin)" >&2
    exit 1
fi

# Apply sensible defaults if the user didn't override
have() { for p in "${PASSTHRU[@]}"; do [ "$p" = "$1" ] && return 0; done; return 1; }
have --limit      || PASSTHRU+=(--limit 5)
have --similarity || PASSTHRU+=(--similarity 0.4)

exec splinterpctl --use "$STORE" search "$QUERY" --bloom "$JOURNAL_LABEL" "${PASSTHRU[@]}"
