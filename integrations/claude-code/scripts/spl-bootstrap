#!/bin/bash
# spl-bootstrap
#
# Idempotently provisions a project-local Splinter memory bus at
# .claude/memory.spl and verifies that the claudevisor service is live so
# splinference will actually embed VARTEXT writes.
#
# Run once per project before agent work begins. Subsequent runs are no-ops
# unless --force is passed, in which case the existing bus is removed and
# recreated (destructive — confirms first).
#
# Geometry rationale:
#   slots  = 2048   (~6 months of journals + ~10 ingested files at ~12 chunks
#                    each + 63 signal slots + headroom)
#   maxlen = 8192   (~2K tokens, fits Nomic v2's training context cleanly)
#   On-disk footprint: ~16 MB

set -e

BUS="${SPLINTER_AGENT_BUS:-.claude/memory.spl}"
SLOTS="${SPLINTER_BOOTSTRAP_SLOTS:-2048}"
MAXLEN="${SPLINTER_BOOTSTRAP_MAXLEN:-8192}"
FORCE=0

for arg in "$@"; do
    case "$arg" in
        --force) FORCE=1 ;;
        --bus)   shift; BUS="$1"; shift || true ;;
        -h|--help)
            cat <<EOF
Usage: $(basename "$0") [--force] [--bus <path>]

Creates a project-local Splinter store at .claude/memory.spl (or \$SPLINTER_AGENT_BUS).
Verifies the claudevisor service is active so splinference will embed writes.

  --force    Recreate the store if it already exists (destructive; prompts).
  --bus PATH Override the bus path.

Environment:
  SPLINTER_AGENT_BUS         Bus path (default: .claude/memory.spl)
  SPLINTER_BOOTSTRAP_SLOTS   Slot count (default: 2048)
  SPLINTER_BOOTSTRAP_MAXLEN  Per-slot max value bytes (default: 8192)
EOF
            exit 0
            ;;
    esac
done

# Step 1: bus
if [ -f "$BUS" ] && [ "$FORCE" -eq 0 ]; then
    echo "[spl-bootstrap] bus exists: $BUS (use --force to recreate)"
else
    if [ -f "$BUS" ] && [ "$FORCE" -eq 1 ]; then
        read -r -p "[spl-bootstrap] remove existing $BUS? [y/N] " yn
        case "$yn" in
            [yY]*) rm -f "$BUS" ;;
            *) echo "[spl-bootstrap] aborted"; exit 1 ;;
        esac
    fi
    mkdir -p "$(dirname "$BUS")"
    splinterpctl init --slots "$SLOTS" --length "$MAXLEN" "$BUS"
    echo "[spl-bootstrap] created $BUS (slots=$SLOTS maxlen=$MAXLEN)"
fi

# Step 2: claudevisor reachability
# claudevisor is the systemd --user unit that runs splinference against the
# project bus. Without it, VARTEXT writes are never embedded and semantic
# search returns nothing meaningful.
if command -v systemctl >/dev/null 2>&1; then
    if systemctl --user is-active --quiet claudevisor; then
        echo "[spl-bootstrap] claudevisor: active"
    else
        echo "[spl-bootstrap] WARN: claudevisor is not active"
        echo "                semantic search and recall will return empty results"
        echo "                start it with: systemctl --user start claudevisor"
    fi
else
    echo "[spl-bootstrap] systemctl not found; cannot verify claudevisor"
fi

# Step 3: emit env hints for the calling shell
cat <<EOF

Set these in your shell (or .envrc) for agent scripts to find the bus:

  export SPLINTER_AGENT_BUS="$BUS"

Bootstrap done. Drop integrations/claude-code/CLAUDE.template.md into
.claude/CLAUDE.md to teach the agent to use this bus.
EOF
