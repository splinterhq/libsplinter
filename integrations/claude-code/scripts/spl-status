#!/bin/bash
# spl-status
#
# One-shot health check of the project memory bus and the claudevisor service
# that drives embedding. Cheap to run; meant to be the first thing an agent
# (or human) runs when something feels off.

STORE="${SPLINTER_AGENT_BUS:-.claude/memory.spl}"

echo "── Splinter memory status ────────────────────────────────"
echo "  bus path : $STORE"

if [ -f "$STORE" ]; then
    SIZE=$(du -h "$STORE" 2>/dev/null | awk '{print $1}')
    echo "  bus file : present ($SIZE)"
else
    echo "  bus file : MISSING — run spl-bootstrap"
fi

if command -v systemctl >/dev/null 2>&1; then
    if systemctl --user is-active --quiet claudevisor; then
        echo "  claudevisor: active"
    else
        STATE=$(systemctl --user is-active claudevisor 2>/dev/null)
        [ -z "$STATE" ] && STATE="unknown"
        echo "  claudevisor: $STATE — embeddings will not happen"
    fi
else
    echo "  claudevisor: cannot check (no systemctl)"
fi

if [ -f "$STORE" ] && command -v splinterpctl >/dev/null 2>&1; then
    echo ""
    echo "── Bus header ────────────────────────────────────────────"
    splinterpctl --use "$STORE" caps 2>/dev/null || echo "  (splinterpctl caps failed)"
fi
