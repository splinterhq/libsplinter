#!/bin/bash
# spl-ingest <file> [--key NAME] [--label HEX]
#
# Ingest a file into the project memory bus as chunked tandem slots.
# Splinference will embed each chunk asynchronously, after which spl-search
# can find passages by meaning. Use this for files you'll revisit across
# turns instead of re-Reading them every time (logs, large source files,
# transcripts, design docs, conversations).
#
# Latency note: embeddings land within a few seconds of ingest depending on
# chunk count and the model loaded by splinference. A 5000-line file split
# into ~30 chunks is typically searchable within ~3-5 seconds. By the next
# tool call or turn it is always ready.

set -e

STORE="${SPLINTER_AGENT_BUS:-.claude/memory.spl}"

if [ "$#" -eq 0 ] || [ "$1" = "-h" ] || [ "$1" = "--help" ]; then
    cat <<EOF
Usage: $(basename "$0") <file> [--key NAME] [--label HEX]
       $(basename "$0") --key NAME              (reads from stdin)

Ingests a file as chunked tandem slots in the project memory bus. Each chunk
is typed VARTEXT and labeled for splinference pickup. A JSON metadata slot
is written to the base key.

  <file>       Path to the file to ingest. Use - to read stdin (requires --key).
  --key NAME   Base key name (default: basename of file).
  --label HEX  Override the chunk label (default: 0x200 ingest-chunk).

After ingest completes, embeddings land within a few seconds. Use spl-search
with --scope ingest to find passages by meaning.

Environment:
  SPLINTER_AGENT_BUS  Bus path (default: .claude/memory.spl)
EOF
    exit 0
fi

# Translate "-" to actual stdin redirection so splinterpctl ingest sees it.
ARGS=()
USE_STDIN=0
for arg in "$@"; do
    if [ "$arg" = "-" ]; then
        USE_STDIN=1
    else
        ARGS+=("$arg")
    fi
done

if [ "$USE_STDIN" -eq 1 ]; then
    splinterpctl --use "$STORE" ingest "${ARGS[@]}"
else
    splinterpctl --use "$STORE" ingest "${ARGS[@]}"
fi

cat >&2 <<EOF

[spl-ingest] embeddings will land asynchronously (typically within seconds).
             search with: spl-search "<query>" --scope ingest
EOF
